---
// src/layouts/Layout.astro
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="lv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Prompt Workshop Coach — strukturēti uzdevumi un AI atgriezeniskā saite" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;600;700;800&family=Manrope:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-background text-on-surface flex flex-col">
    <!-- Fixed glassmorphism header -->
    <header class="bg-white/80 backdrop-blur-xl shadow-sm fixed top-0 w-full z-50 flex items-center justify-between px-4 sm:px-6 h-14 sm:h-16">
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-primary text-2xl">account_balance</span>
        <span class="text-lg font-bold tracking-tight text-primary font-headline">Civic Prompt Workshop</span>
      </div>
    </header>
    <!-- Page content pushed below header -->
    <div class="pt-14 sm:pt-16 flex-1 flex flex-col">
      <slot />
    </div>
  </body>
</html>
