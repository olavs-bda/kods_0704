---
// src/pages/task.astro
import Layout from "../layouts/Layout.astro";
import TaskPage from "../components/TaskPage";
---

<Layout title="Uzdevums — Prompt Workshop Coach">
  {/* Atmospheric background blobs */}
  <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="absolute top-1/3 right-1/4 w-96 h-96 bg-primary-container/15 rounded-full blur-[100px] animate-pulse-soft"></div>
    <div class="absolute bottom-1/4 left-1/4 w-80 h-80 bg-secondary-container/10 rounded-full blur-[80px]"></div>
  </div>
  <main class="relative z-10 mx-auto max-w-2xl px-3 sm:px-4 py-4 sm:py-8">
    <TaskPage client:only="react" />
  </main>
</Layout>
